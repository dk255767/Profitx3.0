      "EXPO_PUBLIC_SUPABASE_URL": "https://zzbmdlxkbbyhzisbtrxo.supabase.co",
      "EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_Ry2PfTWFMKfGjEVlNrh_SA_5Ulf2e8h"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
