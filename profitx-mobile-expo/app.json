        "foregroundImage": "./assets/images/app.png",
        "backgroundImage": "./assets/images/app.png",
        "monochromeImage": "./assets/images/app.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dhanush_2004.profitxmobileexpo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
